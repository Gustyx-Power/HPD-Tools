<Window x:Class="FiveMPoliceOverlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FiveM Police Overlay" 
        Height="200" 
        Width="50"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="10"
        Top="100">
    <Grid>
        <!-- Compact status indicator UI (50x200px) -->
        <Border x:Name="StatusIndicator"
                Background="#80000000"
                CornerRadius="5"
                Padding="5">
            <StackPanel>
                <!-- Mode Indicator -->
                <Border x:Name="ModeIndicator"
                        Background="#FF4CAF50"
                        CornerRadius="3"
                        Padding="5"
                        Margin="0,0,0,5">
                    <TextBlock x:Name="ModeText"
                               Text="PROD"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Success Indicator (hidden by default) -->
                <Border x:Name="SuccessIndicator"
                        Background="#FF4CAF50"
                        CornerRadius="3"
                        Padding="5"
                        Margin="0,0,0,5"
                        Visibility="Collapsed">
                    <TextBlock Text="✓"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Cooldown Indicator (hidden by default) -->
                <Border x:Name="CooldownIndicator"
                        Background="#FFF44336"
                        CornerRadius="3"
                        Padding="5"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⏱"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CooldownText"
                                   Text="2s"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
